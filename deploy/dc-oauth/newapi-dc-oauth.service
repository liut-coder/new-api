[Unit]
Description=New API Universe Federation OAuth Bridge v2 App Auth
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/newapi-dc-oauth
ExecStart=/opt/newapi-dc-oauth/run.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
